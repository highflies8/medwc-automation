  <sys_variable_value action="INSERT_OR_UPDATE">
    <sys_id>40f14d32f31544119b35cdf96a4cf9d7</sys_id>
    <sys_scope display_value="x_snc_medwc_auto_0">2c25847dc365875409e6d063e4013179</sys_scope>
