        <condition/>
        <description>Automatically syncs the state field when the AI Agent updates agent_decision. Maps Approve to Resolved (3), Deny to Closed (4), and Escalate to Pending (-5).</description>
        <execute_function>false</execute_function>
        <filter_condition table="x_snc_medwc_auto_0_warranty_claim">agent_decisionVALCHANGES<item display_value="-- None --" endquery="false" field="agent_decision" goto="false" newquery="false" operator="VALCHANGES" or="false" value=""/>
        </filter_condition>
        <is_rest>false</is_rest>
        <message/>
        <name>Sync Status with Agent Decision</name>
        <order>100</order>
        <priority>100</priority>
        <rest_method/>
        <rest_method_text/>
        <rest_service/>
        <rest_service_text/>
        <rest_variables/>
        <role_conditions/>
        <script><![CDATA[(function executeRule(current, previous) {
    var decision = current.getValue("agent_decision");

    if (decision === "approve") {
        current.setValue("state", "3"); // Resolved - triggers fulfillment flow
    } else if (decision === "deny") {
        current.setValue("state", "4"); // Closed - triggers denied notification flow
    } else if (decision === "escalate") {
        current.setValue("state", "-5"); // Pending - on hold for human review
    }
})(current, previous);
]]></script>
